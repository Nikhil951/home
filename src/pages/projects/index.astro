---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/path';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Projects — Nikhil Tiwari" description="Things I've designed and built.">
  <header class="page-head">
    <p class="eyebrow">Projects</p>
    <h1>Things I've built</h1>
    <p class="prose" style="color: var(--ink-soft); font-size: 1.15rem;">
      A selection of products, experiments, and client work.
    </p>
  </header>

  <ul class="entry-list">
    {projects.map((p) => (
      <EntryCard
        href={withBase(`/projects/${p.id}/`)}
        title={p.data.title}
        description={p.data.description}
        date={p.data.date}
        tags={p.data.tags}
      />
    ))}
  </ul>
</BaseLayout>

<style>
  .page-head { padding: clamp(1.5rem, 5vw, 3rem) 0 2rem; }
  .page-head h1 { margin: 0.8rem 0 1rem; }
</style>
