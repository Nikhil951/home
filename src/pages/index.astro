---
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/path';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const focusAreas = [
  {
    title: 'Engineering Leadership',
    desc: 'Guiding technical direction and decision-making across teams and platforms.',
  },
  {
    title: 'Distributed Systems & Scalability',
    desc: 'Designing high-volume backend systems that stay reliable as they grow.',
  },
  {
    title: 'System Design & Architecture',
    desc: 'Shaping pragmatic architectures that balance trade-offs with business outcomes.',
  },
  {
    title: 'Platform Engineering',
    desc: 'Building the foundations and tooling that let product teams move faster.',
  },
  {
    title: 'Cloud & Microservices',
    desc: 'Cloud-native services designed for resilience, scale, and operability.',
  },
  {
    title: 'Elasticsearch & Search',
    desc: 'Powering fast, relevant search across large and complex datasets.',
  },
  {
    title: 'Reliability & Observability',
    desc: 'Instrumenting systems for visibility and engineering for uptime.',
  },
  {
    title: 'Technical Mentorship',
    desc: 'Helping engineers grow and teams collaborate with lasting impact.',
  },
];
---

<BaseLayout
  title="Nikhil Tiwari — Staff Engineer"
  description="Nikhil Tiwari — Staff Engineer working across distributed systems, platform engineering, and engineering leadership."
>
  <section class="hero">
    <p class="eyebrow eyebrow--accent">Staff Engineer · Engineering Leadership</p>
    <h1>
      I scale both <span class="accent">systems</span><br />
      and <span class="accent">people</span>.
    </h1>
    <p class="hero__lede prose">
      I lead technical initiatives across distributed platforms — driving
      architecture decisions, engineering excellence, and cross-functional
      collaboration to deliver reliable, scalable products.
    </p>
    <div class="hero__cta">
      <a href="mailto:nikhiltiwari951@gmail.com" class="btn">Get in touch</a>
      <a
        href="https://www.linkedin.com/in/nikhil-tiwari-265562105/"
        class="link"
        target="_blank"
        rel="noopener"
      >LinkedIn ↗</a>
    </div>
  </section>

  <section id="about" class="block">
    <header class="block__head">
      <h2>About</h2>
    </header>
    <div class="prose about">
      <p>
        I lead technical initiatives across distributed platforms, driving
        architecture decisions, engineering excellence, and cross-functional
        collaboration to deliver reliable, scalable products. My experience
        spans high-volume backend systems, travel commerce platforms, platform
        engineering, and cloud-native architectures.
      </p>
      <p>
        Beyond technology, I enjoy mentoring engineers, influencing technical
        strategy, and helping teams navigate complex challenges while
        maintaining a strong focus on business outcomes.
      </p>
      <blockquote>
        Great engineering is not only about building systems that scale, but
        also about enabling teams to grow, collaborate effectively, and deliver
        meaningful impact.
      </blockquote>
    </div>
  </section>

  <section id="focus" class="block">
    <header class="block__head">
      <h2>Areas of focus</h2>
    </header>
    <ul class="focus-grid">
      {focusAreas.map((a, i) => (
        <li class="focus-item">
          <span class="focus-item__num">{String(i + 1).padStart(2, '0')}</span>
          <h3>{a.title}</h3>
          <p>{a.desc}</p>
        </li>
      ))}
    </ul>
  </section>

  {posts.length > 0 && (
    <section id="writing" class="block">
      <header class="block__head">
        <h2>Writing</h2>
        <a href={withBase('/blog')} class="link">All posts →</a>
      </header>
      <ul class="entry-list">
        {posts.map((p) => (
          <EntryCard
            href={withBase(`/blog/${p.id}/`)}
            title={p.data.title}
            description={p.data.description}
            date={p.data.date}
            tags={p.data.tags}
          />
        ))}
      </ul>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: clamp(2.5rem, 9vw, 7rem) 0 clamp(3rem, 7vw, 5.5rem);
    border-bottom: 1px solid var(--line);
  }
  .eyebrow--accent { color: var(--accent); }
  .hero h1 { margin: 1.25rem 0 1.5rem; max-width: 18ch; }
  .hero h1 .accent { color: var(--accent); }
  .hero__lede { font-size: 1.15rem; color: var(--ink-soft); }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2.25rem;
  }
  .btn {
    display: inline-block;
    background: var(--accent);
    color: var(--accent-contrast);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.7rem 1.3rem;
    border-radius: 3px;
    transition: background 0.15s ease;
  }
  .btn:hover { background: var(--accent-deep); }

  .block { margin-top: clamp(3rem, 7vw, 5rem); }
  .block__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.75rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--line);
  }

  .about p { font-size: 1.1rem; color: var(--ink-soft); }
  .about blockquote {
    margin: 2rem 0 0;
    padding-left: 1.25rem;
    border-left: 2px solid var(--accent);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1.2rem;
    color: var(--ink);
  }

  /* strict hairline grid */
  .focus-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }
  .focus-item {
    padding: 1.5rem;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .focus-item__num {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-faint);
    margin-bottom: 0.6rem;
  }
  .focus-item h3 { font-size: 1rem; font-weight: 600; margin: 0 0 0.4rem; }
  .focus-item p { font-size: 0.9rem; color: var(--ink-soft); margin: 0; }

  @media (max-width: 38rem) {
    .focus-grid { grid-template-columns: 1fr; }
  }
</style>
